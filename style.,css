<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Física 2º Bachillerato</title>

<style>

/* RESET */
* {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
}

/* VARIABLES */
:root {
    --primary: #00e5ff;
    --primary-dark: #00bcd4;
    --bg-1: #0f2027;
    --bg-2: #203a43;
    --bg-3: #2c5364;

    --glass: rgba(255,255,255,0.06);
    --border: rgba(255,255,255,0.15);

    --text: #ffffff;
    --text-muted: rgba(255,255,255,0.7);

    --shadow-soft: 0 8px 25px rgba(0,0,0,0.3);
    --shadow-strong: 0 15px 50px rgba(0,0,0,0.6);

    --radius: 20px;
    --transition: 0.35s cubic-bezier(.2,.8,.2,1);
}

/* BODY */
body {
    font-family: 'Poppins', sans-serif;
    background: linear-gradient(135deg, var(--bg-1), var(--bg-2), var(--bg-3));
    color: var(--text);
}

/* HEADER */
header {
    text-align: center;
    padding: 80px 20px;
    background: rgba(0,0,0,0.5);
    backdrop-filter: blur(20px);
}

header h1 {
    font-size: 3rem;
    background: linear-gradient(90deg, var(--primary), var(--primary-dark));
    -webkit-background-clip: text;
    color: transparent;
}

header p {
    margin-top: 15px;
    color: var(--text-muted);
}

/* NAV */
nav {
    display: flex;
    justify-content: center;
    gap: 30px;
    padding: 15px;
    background: rgba(255,255,255,0.05);
    backdrop-filter: blur(15px);
    position: sticky;
    top: 0;
}

nav a {
    color: var(--text-muted);
    text-decoration: none;
    position: relative;
}

nav a:hover {
    color: var(--primary);
}

/* SECCIONES */
section {
    padding: 60px 10%;
}

/* TITULOS */
h2 {
    font-size: 2rem;
    margin-bottom: 30px;
}

h3 {
    color: var(--primary);
    margin-bottom: 10px;
}

/* GRID */
.cards-container {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 25px;
}

/* CARDS */
.card {
    background: var(--glass);
    padding: 25px;
    border-radius: var(--radius);
    backdrop-filter: blur(20px);
    border: 1px solid var(--border);
    transition: var(--transition);
}

.card:hover {
    transform: translateY(-10px) scale(1.02);
    box-shadow: var(--shadow-strong);
}

/* FOOTER */
footer {
    text-align: center;
    padding: 30px;
    background: rgba(0,0,0,0.6);
    color: var(--text-muted);
}

</style>
</head>

<body>

<header>
    <h1>Física 2º Bachillerato</h1>
    <p>Domina la física como un profesional 🚀</p>
</header>

<nav>
    <a href="#cinematica">Cinemática</a>
    <a href="#dinamica">Dinámica</a>
    <a href="#energia">Energía</a>
</nav>

<section id="cinematica">
    <h2>Cinemática</h2>
    <div class="cards-container">
        <div class="card">
            <h3>Movimiento Rectilíneo</h3>
            <p>MRU y MRUA. v = d/t</p>
        </div>

        <div class="card">
            <h3>Movimiento Parabólico</h3>
            <p>Movimiento en 2D bajo gravedad.</p>
        </div>

        <div class="card">
            <h3>Movimiento Circular</h3>
            <p>Aceleración centrípeta: a = v²/r</p>
        </div>
    </div>
</section>

<section id="dinamica">
    <h2>Dinámica</h2>
    <div class="cards-container">
        <div class="card">
            <h3>Leyes de Newton</h3>
            <p>Las 3 leyes fundamentales del movimiento.</p>
        </div>

        <div class="card">
            <h3>Fuerzas</h3>
            <p>Gravedad, rozamiento, tensión y normal.</p>
        </div>

        <div class="card">
            <h3>Aplicaciones</h3>
            <p>Resolución de problemas reales.</p>
        </div>
    </div>
</section>

<section id="energia">
    <h2>Energía y Trabajo</h2>
    <div class="cards-container">
        <div class="card">
            <h3>Energía Cinética</h3>
            <p>Ec = ½mv²</p>
        </div>

        <div class="card">
            <h3>Energía Potencial</h3>
            <p>Energía almacenada por posición.</p>
        </div>

        <div class="card">
            <h3>Trabajo</h3>
            <p>Relación entre fuerza y desplazamiento.</p>
        </div>
    </div>
</section>

<footer>
    <p>© 2026 Física Pro | Hecho por Alejandro</p>
</footer>

</body>
</html>
