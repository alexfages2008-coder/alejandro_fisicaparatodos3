/* =======================
   RESET
======================= */
*{
  margin:0;
  padding:0;
  box-sizing:border-box;
}

/* =======================
   BODY
======================= */
body{
  font-family:'Inter',sans-serif;
  background:#0f172a;
  color:#e2e8f0;
  display:flex;
}

/* =======================
   SIDEBAR (MENÚ)
======================= */
.sidebar{
  width:260px;
  height:100vh;
  background:#020617;
  padding:30px 20px;
  position:fixed;
  display:flex;
  flex-direction:column;
}

.sidebar h2{
  color:#38bdf8;
  margin-bottom:30px;
  font-size:1.5rem;
}

/* BOTONES MENU */
.sidebar a{
  display:block;
  padding:12px;
  margin:8px 0;
  border-radius:8px;
  color:#94a3b8;
  text-decoration:none;
  transition:0.3s;
}

.sidebar a:hover{
  background:#1e293b;
  color:#38bdf8;
  transform:translateX(5px);
}

/* =======================
   CONTENIDO
======================= */
.main{
  margin-left:260px;
  padding:40px;
  width:100%;
}

/* HEADER */
.header h1{
  font-size:2.5rem;
  margin-bottom:10px;
}

.header p{
  color:#94a3b8;
}

/* =======================
   SECCIONES
======================= */
.section{
  margin-top:50px;
}

.section h2{
  color:#38bdf8;
  margin-bottom:20px;
}

/* GRID */
.grid{
  display:grid;
  grid-template-columns:repeat(auto-fit,minmax(250px,1fr));
  gap:20px;
}

/* =======================
   CARDS
======================= */
.card{
  background:#1e293b;
  padding:20px;
  border-radius:12px;
  transition:0.3s;
  border:1px solid transparent;
  cursor:pointer;
}

.card:hover{
  transform:translateY(-5px);
  border:1px solid #38bdf8;
}

.card h3{
  margin-bottom:10px;
}

/* =======================
   BOTONES GENERALES
======================= */
button{
  background:#38bdf8;
  color:#020617;
  border:none;
  padding:10px 15px;
  border-radius:8px;
  cursor:pointer;
  font-weight:bold;
  transition:0.3s;
}

button:hover{
  background:#0ea5e9;
  transform:scale(1.05);
}

/* =======================
   CHATBOT
======================= */
#chatBox{
  background:#1e293b;
  border-radius:10px;
  padding:10px;
  height:250px;
  overflow-y:auto;
  margin-top:10px;
  border:1px solid #334155;
}

/* MENSAJES */
#chatBox div{
  margin:5px 0;
  padding:8px;
  border-radius:8px;
}

#chatBox div strong{
  color:#38bdf8;
}

/* INPUT */
#inputChat{
  width:70%;
  padding:10px;
  border-radius:8px;
  border:none;
  outline:none;
  background:#020617;
  color:white;
  margin-top:10px;
}

/* =======================
   SCROLL BONITO
======================= */
#chatBox::-webkit-scrollbar{
  width:6px;
}

#chatBox::-webkit-scrollbar-thumb{
  background:#38bdf8;
  border-radius:10px;
}

/* =======================
   RESPONSIVE
======================= */
@media(max-width:768px){

  body{
    flex-direction:column;
  }

  .sidebar{
    position:relative;
    width:100%;
    height:auto;
    flex-direction:row;
    overflow-x:auto;
  }

  .sidebar a{
    margin:5px;
    white-space:nowrap;
  }

  .main{
    margin-left:0;
    padding:20px;
  }

  #inputChat{
    width:100%;
  }
}
