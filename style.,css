/* ===============================
   🌌 RESET MODERNO
================================ */
*,
*::before,
*::after {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
}

/* ===============================
   🎨 VARIABLES PRO (THEME READY)
================================ */
:root {
    --primary: #00e5ff;
    --primary-dark: #00bcd4;
    --bg-1: #0f2027;
    --bg-2: #203a43;
    --bg-3: #2c5364;

    --glass: rgba(255, 255, 255, 0.06);
    --glass-strong: rgba(255, 255, 255, 0.12);

    --text: #ffffff;
    --text-muted: rgba(255,255,255,0.7);

    --border: rgba(255,255,255,0.15);

    --shadow-soft: 0 8px 25px rgba(0,0,0,0.3);
    --shadow-strong: 0 15px 50px rgba(0,0,0,0.6);

    --radius: 20px;
    --transition: 0.35s cubic-bezier(.2,.8,.2,1);
}

/* ===============================
   🌍 BODY MEJORADO
================================ */
html {
    scroll-behavior: smooth;
}

body {
    font-family: 'Poppins', sans-serif;
    background: linear-gradient(135deg, var(--bg-1), var(--bg-2), var(--bg-3));
    color: var(--text);
    overflow-x: hidden;
}

/* FONDO ANIMADO SUTIL */
body::before {
    content: "";
    position: fixed;
    width: 200%;
    height: 200%;
    background: radial-gradient(circle, rgba(0,229,255,0.08), transparent 60%);
    animation: bgMove 20s linear infinite;
    z-index: -1;
}

@keyframes bgMove {
    0% { transform: translate(-25%, -25%); }
    100% { transform: translate(25%, 25%); }
}

/* ===============================
   🔝 HEADER PRO
================================ */
header {
    text-align: center;
    padding: 80px 20px;
    background: rgba(0,0,0,0.55);
    backdrop-filter: blur(20px);
    border-bottom: 1px solid var(--border);
}

header h1 {
    font-size: 3.8rem;
    letter-spacing: 4px;
    background: linear-gradient(90deg, var(--primary), var(--primary-dark));
    -webkit-background-clip: text;
    color: transparent;
    animation: glow 2s infinite alternate;
}

@keyframes glow {
    from { text-shadow: 0 0 10px rgba(0,229,255,0.4); }
    to { text-shadow: 0 0 25px rgba(0,229,255,0.9); }
}

header p {
    margin-top: 15px;
    color: var(--text-muted);
    font-size: 1.1rem;
}

/* ===============================
   🧭 NAVBAR PRO
================================ */
nav {
    display: flex;
    justify-content: center;
    gap: 40px;
    padding: 18px;
    background: rgba(255,255,255,0.04);
    backdrop-filter: blur(15px);
    position: sticky;
    top: 0;
    z-index: 1000;
    border-bottom: 1px solid var(--border);
}

nav a {
    color: var(--text);
    text-decoration: none;
    font-weight: 600;
    position: relative;
    transition: var(--transition);
}

nav a:hover {
    color: var(--primary);
}

/* ANIMACIÓN SUBRAYADO PRO */
nav a::after {
    content: "";
    position: absolute;
    width: 0%;
    height: 2px;
    bottom: -6px;
    left: 50%;
    transform: translateX(-50%);
    background: var(--primary);
    transition: var(--transition);
}

nav a:hover::after {
    width: 100%;
}

/* ===============================
   📦 SECCIONES PRO
================================ */
section {
    padding: 100px 10%;
    animation: fadeInUp 1s ease;
}

h2 {
    margin-bottom: 40px;
    font-size: 2.3rem;
    border-left: 6px solid var(--primary);
    padding-left: 15px;
}

/* ===============================
   🧱 GRID MEJORADO
================================ */
.grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
    gap: 30px;
}

/* ===============================
   💎 CARDS ULTRA PRO
================================ */
.card {
    background: var(--glass);
    border-radius: var(--radius);
    padding: 30px;
    box-shadow: var(--shadow-soft);
    backdrop-filter: blur(20px);
    border: 1px solid var(--border);
    transition: var(--transition);
    position: relative;
    overflow: hidden;
}

/* EFECTO LUZ DINÁMICO */
.card::before {
    content: "";
    position: absolute;
    inset: 0;
    background: linear-gradient(120deg, transparent, rgba(0,229,255,0.3), transparent);
    opacity: 0;
    transition: var(--transition);
}

.card:hover::before {
    opacity: 1;
}

/* HOVER PRO */
.card:hover {
    transform: translateY(-12px) scale(1.04);
    box-shadow: var(--shadow-strong);
}

/* ===============================
   🔘 BOTONES PRO
================================ */
.btn {
    display: inline-block;
    margin-top: 15px;
    padding: 12px 28px;
    background: linear-gradient(90deg, var(--primary), var(--primary-dark));
    color: black;
    border-radius: 50px;
    text-decoration: none;
    font-weight: bold;
    transition: var(--transition);
    box-shadow: 0 0 15px rgba(0,229,255,0.5);
}

.btn:hover {
    transform: scale(1.12);
    box-shadow: 0 0 30px rgba(0,229,255,0.9);
}

/* ===============================
   📊 FOOTER PRO
================================ */
footer {
    text-align: center;
    padding: 40px;
    background: rgba(0,0,0,0.7);
    border-top: 1px solid var(--border);
    color: var(--text-muted);
}

/* ===============================
   ✨ ANIMACIONES PRO
================================ */
@keyframes fadeInUp {
    from {
        opacity: 0;
        transform: translateY(60px);
    }
    to {
        opacity: 1;
        transform: translateY(0);
    }
}

/* ===============================
   📱 RESPONSIVE PRO
================================ */
@media (max-width: 768px) {
    header h1 {
        font-size: 2.4rem;
    }

    nav {
        flex-wrap: wrap;
        gap: 15px;
    }

    section {
        padding: 60px 5%;
    }
}

/* ===============================
   🌟 SCROLLBAR PRO
================================ */
::-webkit-scrollbar {
    width: 10px;
}

::-webkit-scrollbar-thumb {
    background: linear-gradient(var(--primary), var(--primary-dark));
    border-radius: 10px;
}
