/* ===============================
   🌌 RESET MODERNO
================================ */
*,
*::before,
*::after {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
}

/* ===============================
   🎨 VARIABLES PRO (THEME READY)
================================ */
:root {
    --primary: #00e5ff;
    --primary-dark: #00bcd4;
    --bg-1: #0f2027;
    --bg-2: #203a43;
    --bg-3: #2c5364;

    --glass: rgba(255, 255, 255, 0.06);
    --glass-strong: rgba(255, 255, 255, 0.12);

    --text: #ffffff;
    --text-muted: rgba(255,255,255,0.7);

    --border: rgba(255,255,255,0.15);

    --shadow-soft: 0 8px 25px rgba(0,0,0,0.3);
    --shadow-strong: 0 15px 50px rgba(0,0,0,0.6);

    --radius: 20px;
    --transition: 0.35s cubic-bezier(.2,.8,.2,1);
}

/* ===============================
   🌍 BODY
================================ */
html {
    scroll-behavior: smooth;
}

body {
    font-family: 'Poppins', sans-serif;
    background: linear-gradient(135deg, var(--bg-1), var(--bg-2), var(--bg-3));
    color: var(--text);
    overflow-x: hidden;
}

/* FONDO */
body::before {
    content: "";
    position: fixed;
    width: 200%;
    height: 200%;
    background: radial-gradient(circle, rgba(0,229,255,0.08), transparent 60%);
    animation: bgMove 20s linear infinite;
    z-index: -1;
}

@keyframes bgMove {
    0% { transform: translate(-25%, -25%); }
    100% { transform: translate(25%, 25%); }
}

/* ===============================
   🔝 HEADER
================================ */
header {
    text-align: center;
    padding: 80px 20px;
    background: rgba(0,0,0,0.55);
    backdrop-filter: blur(20px);
    border-bottom: 1px solid var(--border);
}

header h1 {
    font-size: 3.8rem;
    letter-spacing: 4px;
    background: linear-gradient(90deg, var(--primary), var(--primary-dark));
    -webkit-background-clip: text;
    color: transparent;
    animation: glow 2s infinite alternate;
}

@keyframes glow {
    from { text-shadow: 0 0 10px rgba(0,229,255,0.4); }
    to { text-shadow: 0 0 25px rgba(0,229,255,0.9); }
}

/* ===============================
   🧭 NAVBAR
================================ */
nav {
    display: flex;
    justify-content: center;
    gap: 40px;
    padding: 18px;
    background: rgba(255,255,255,0.04);
    backdrop-filter: blur(15px);
    position: sticky;
    top: 0;
    z-index: 1000;
    border-bottom: 1px solid var(--border);
}

/* ===============================
   📦 SECCIONES
================================ */
section {
    padding: 100px 10%;
    animation: fadeInUp 1s ease;
}

/* ===============================
   💎 CARDS
================================ */
.card {
    background: var(--glass);
    border-radius: var(--radius);
    padding: 30px;
    box-shadow: var(--shadow-soft);
    backdrop-filter: blur(20px);
    border: 1px solid var(--border);
    transition: var(--transition);
}

/* ===============================
   🤖 CHATBOT PRO
================================ */
#chatbot {
    text-align: center;
}

.chat-container {
    max-width: 500px;
    margin: 30px auto;
    padding: 20px;
    border-radius: var(--radius);
    background: var(--glass);
    backdrop-filter: blur(20px);
    border: 1px solid var(--border);
    box-shadow: var(--shadow-soft);
}

/* caja mensajes */
#chatbox {
    height: 260px;
    overflow-y: auto;
    padding: 15px;
    border-radius: 12px;
    background: rgba(0,0,0,0.3);
    margin-bottom: 15px;
    font-size: 0.95rem;
}

/* mensajes */
.user {
    text-align: right;
    margin: 8px 0;
    color: #4fc3f7;
}

.bot {
    text-align: left;
    margin: 8px 0;
    color: #00e5ff;
}

/* input */
#userInput {
    width: 70%;
    padding: 10px;
    border-radius: 20px;
    border: none;
    outline: none;
    background: rgba(255,255,255,0.1);
    color: white;
}

/* botón */
#chatbot button {
    padding: 10px 18px;
    border-radius: 20px;
    border: none;
    background: linear-gradient(90deg, var(--primary), var(--primary-dark));
    cursor: pointer;
    font-weight: bold;
    transition: var(--transition);
}

#chatbot button:hover {
    transform: scale(1.1);
    box-shadow: 0 0 15px rgba(0,229,255,0.7);
}

/* ===============================
   📊 FOOTER
================================ */
footer {
    text-align: center;
    padding: 40px;
    background: rgba(0,0,0,0.7);
    border-top: 1px solid var(--border);
    color: var(--text-muted);
}

/* ===============================
   📱 RESPONSIVE
================================ */
@media (max-width: 768px) {
    #userInput {
        width: 100%;
        margin-bottom: 10px;
    }

    #chatbot button {
        width: 100%;
    }
}
