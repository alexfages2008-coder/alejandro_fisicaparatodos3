<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Física Pro</title>

<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;500;700&display=swap" rel="stylesheet">

<style>

/* RESET */
*{margin:0;padding:0;box-sizing:border-box}

/* BODY */
body{
font-family:'Inter',sans-serif;
background:#0f172a;
color:white;
display:flex;
}

/* SIDEBAR */
.sidebar{
width:250px;
height:100vh;
background:#020617;
padding:30px 20px;
position:fixed;
}

.sidebar h2{
color:#38bdf8;
margin-bottom:30px;
}

.sidebar a{
display:block;
color:#94a3b8;
text-decoration:none;
margin:15px 0;
transition:0.2s;
}

.sidebar a:hover{
color:#38bdf8;
transform:translateX(5px);
}

/* CONTENIDO */
.main{
margin-left:250px;
padding:40px;
width:100%;
}

/* HEADER */
.header{
margin-bottom:40px;
}

.header h1{
font-size:2.5rem;
}

/* GRID */
.grid{
display:grid;
grid-template-columns:repeat(auto-fit,minmax(250px,1fr));
gap:20px;
}

/* CARDS */
.card{
background:#1e293b;
padding:20px;
border-radius:12px;
transition:0.3s;
border:1px solid transparent;
}

.card:hover{
transform:translateY(-5px);
border:1px solid #38bdf8;
}

/* TITULOS */
.section{
margin-bottom:50px;
}

.section h2{
margin-bottom:20px;
color:#38bdf8;
}

.card h3{
margin-bottom:10px;
}

/* RESPONSIVE */
@media(max-width:768px){
.sidebar{
position:relative;
width:100%;
height:auto;
}

.main{
margin-left:0;
}
}

</style>
</head>

<body>

<div class="sidebar">
<h2>Física ⚡</h2>
<a href="#cinematica">Cinemática</a>
<a href="#dinamica">Dinámica</a>
<a href="#energia">Energía</a>
</div>

<div class="main">

<div class="header">
<h1>Física 2º Bachillerato</h1>
<p>Aprende rápido y claro</p>
</div>

<div class="section" id="cinematica">
<h2>Cinemática</h2>
<div class="grid">
<div class="card"><h3>MRU/MRUA</h3><p>v = d/t</p></div>
<div class="card"><h3>Parabólico</h3><p>Movimiento 2D</p></div>
<div class="card"><h3>Circular</h3><p>a = v²/r</p></div>
</div>
</div>

<div class="section" id="dinamica">
<h2>Dinámica</h2>
<div class="grid">
<div class="card"><h3>Leyes de Newton</h3></div>
<div class="card"><h3>Fuerzas</h3></div>
<div class="card"><h3>Aplicaciones</h3></div>
</div>
</div>

<div class="section" id="energia">
<h2>Energía</h2>
<div class="grid">
<div class="card"><h3>Energía Cinética</h3><p>½mv²</p></div>
<div class="card"><h3>Potencial</h3></div>
<div class="card"><h3>Trabajo</h3></div>
</div>
</div>

</div>

</body>
</html>
