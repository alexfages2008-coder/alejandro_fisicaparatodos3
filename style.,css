/* RESET */
* {
  margin: 0;
  padding: 0;
  box-sizing: border-box;
}

/* BODY */
body {
  font-family: 'Inter', sans-serif;
  background-color: #0f172a;
  color: #e2e8f0;
  display: flex;
  min-height: 100vh;
}

/* SIDEBAR */
.sidebar {
  width: 250px;
  background-color: #020617;
  padding: 30px 20px;
  position: fixed;
  height: 100vh;
  overflow-y: auto;
  display: flex;
  flex-direction: column;
  align-items: start;
}

.sidebar h2 {
  color: #38bdf8;
  margin-bottom: 30px;
  font-size: 1.8rem;
}

.sidebar nav a {
  color: #94a3b8;
  text-decoration: none;
  margin: 12px 0;
  display: block;
  padding: 8px 12px;
  border-radius: 8px;
  transition: background-color 0.3s ease, color 0.3s ease;
}

.sidebar nav a:hover {
  background-color: #1e293b;
  color: #38bdf8;
}

/* MAIN */
.main {
  margin-left: 250px;
  padding: 40px;
  flex-grow: 1;
  max-width: calc(100% - 250px);
  overflow-y: auto;
}

/* HEADER */
.header h1 {
  font-size: 2.8rem;
  margin-bottom: 10px;
  color: #38bdf8;
}

.header p {
  color: #94a3b8;
  font-size: 1.2rem;
  margin-bottom: 30px;
}

/* SECTIONS */
.section {
  margin-bottom: 50px;
}

.section h2 {
  color: #38bdf8;
  margin-bottom: 20px;
  border-bottom: 2px solid #38bdf8;
  padding-bottom: 5px;
  font-weight: 700;
}

/* GRID */
.grid {
  display: grid;
  grid-template-columns: repeat(auto-fit,minmax(250px,1fr));
  gap: 20px;
}

/* CARDS */
.card {
  background-color: #1e293b;
  padding: 20px;
  border-radius: 12px;
  cursor: pointer;
  box-shadow: 0 2px 6px rgba(0,0,0,0.5);
  transition: transform 0.3s ease, box-shadow 0.3s ease;
  border: 2px solid transparent;
}

.card:hover {
  transform: translateY(-7px);
  box-shadow: 0 10px 20px rgba(56, 221, 248, 0.6);
  border-color: #38bdf8;
}

.card h3 {
  margin-bottom: 10px;
  color: #38bdf8;
}

.card p {
  color: #cbd5e1;
}

/* FORMULA DISPLAY */
#formulaDisplay {
  background-color: #1e293b;
  padding: 20px;
  border-radius: 12px;
  font-size: 1.4rem;
  color: #38bdf8;
  min-height: 50px;
  box-shadow: inset 0 0 10px #0ea5e9;
}

/* CHATBOT */
#chatbot {
  max-width: 600px;
}

#chatBox {
  background-color: #1e293b;
  height: 300px;
  border-radius: 10px;
  padding: 15px;
  overflow-y: auto;
  box-shadow: 0 0 15px #38bdf8aa;
  font-size: 1rem;
  line-height: 1.4;
  color: #e2e8f0;
}

#chatBox div {
  margin-bottom: 12px;
  padding: 8px 12px;
  border-radius: 8px;
  background-color: #0f172a;
  box-shadow: inset 0 0 5px #0ea5e9aa;
}

#chatBox div.bot {
  background-color: #164e63;
}

#chatBox div.user {
  background-color: #1e293b;
  text-align: right;
}

#chatInput {
  width: calc(100% - 100px);
  margin-top: 10px;
  padding: 12px 15px;
  border-radius: 10px;
  border: none;
  background-color: #020617;
  color: #e2e8f0;
  font-size: 1rem;
  outline: none;
  box-shadow: 0 0 8px #38bdf8aa;
  transition: background-color 0.3s ease;
}

#chatInput::placeholder {
  color: #94a3b8;
}

#sendBtn {
  width: 80px;
  margin-left: 10px;
  padding: 12px 15px;
  border-radius: 10px;
  border: none;
  background-color: #38bdf8;
  color: #020617;
  font-weight: 700;
  cursor: pointer;
  transition: background-color 0.3s ease;
}

#sendBtn:hover {
  background-color: #0ea5e9;
}

/* RESPONSIVE */
@media (max-width: 768px) {
  body {
    flex-direction: column;
  }

  .sidebar {
    width: 100%;
    height: auto;
    position: relative;
    flex-direction: row;
    overflow-x: auto;
    padding: 15px;
  }

  .sidebar nav a {
    margin: 0 10px;
    padding: 10px 15px;
    white-space: nowrap;
  }

  .main {
    margin-left: 0;
    padding: 20px;
  }

  #chatbot {
    max-width: 100%;
  }

  #chatInput {
    width: calc(100% - 100px);
  }
}
